# ─── API ──────────────────────────────────────────────────────
# Backend URL (your Render deployment URL + /api)
# Leave blank for local dev — Vite proxy handles it automatically
VITE_API_URL=

# ─── OAuth ────────────────────────────────────────────────────
# Google OAuth Client ID (same as server's GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=
