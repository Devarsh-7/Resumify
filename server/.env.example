# ─── Database ─────────────────────────────────────────────────
# MongoDB Atlas connection string
# Get yours at: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/resumify?retryWrites=true&w=majority

# ─── Authentication ───────────────────────────────────────────
# JWT secret (generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=

# Google OAuth Client ID (https://console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=

# ─── AI ───────────────────────────────────────────────────────
# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# ─── Email Verification ──────────────────────────────────────
# Gmail SMTP (enable 2FA → create App Password at https://myaccount.google.com/apppasswords)
EMAIL_USER=
EMAIL_PASS=

# ─── Server ──────────────────────────────────────────────────
# Port (Render sets this automatically, 5000 for local dev)
PORT=5000

# Frontend URL — needed for CORS (set after deploying frontend)
CLIENT_URL=http://localhost:5173